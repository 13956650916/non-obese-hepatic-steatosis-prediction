def calculate_metrics(y_true, prob, class_names):

    y_pred = np.argmax(prob, axis=1)
    y_bin = label_binarize(y_true, classes=[0,1,2])

    results = {}

    results["Accuracy"] = accuracy_score(y_true, y_pred)
    results["Cohen_Kappa"] = cohen_kappa_score(y_true, y_pred)

    results["macro_ROC_AUCg"] = roc_auc_score(
        y_bin, prob, average="macro", multi_class="ovr"
    )

    results["micro_ROC_AUCh"] = roc_auc_score(
        y_bin, prob, average="micro", multi_class="ovr"
    )

    # PR AUC
    results["macro_PR_AUC"] = roc_auc_score(
        y_bin, prob, average="macro"
    )

    results["micro_PR_AUC"] = roc_auc_score(
        y_bin, prob, average="micro"
    )

    cm = confusion_matrix(y_true, y_pred)

    for i, name in enumerate(class_names):

        TP = cm[i, i]
        FP = cm[:, i].sum() - TP
        FN = cm[i, :].sum() - TP
        TN = cm.sum() - TP - FP - FN

        results[f"Precision({name})"] = TP / (TP + FP) if (TP+FP)>0 else 0
        results[f"Recall({name})"] = TP / (TP + FN) if (TP+FN)>0 else 0
        results[f"Sensitivity({name})"] = results[f"Recall({name})"]
        results[f"Specificity({name})"] = TN / (TN + FP) if (TN+FP)>0 else 0
        results[f"F1({name})"] = (
            2 * TP / (2*TP + FP + FN) if (2*TP+FP+FN)>0 else 0
        )

        results[f"ROC_AUC({name})"] = roc_auc_score(
            y_bin[:, i], prob[:, i]
        )

    return results



