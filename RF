def plot_multiclass_roc(y_bin, prob_mean, title):

    n_classes = y_bin.shape[1]

    fpr = dict()
    tpr = dict()
    roc_auc = dict()

    for i in range(n_classes):
        fpr[i], tpr[i], _ = roc_curve(y_bin[:, i], prob_mean[:, i])
        roc_auc[i] = auc(fpr[i], tpr[i])

    # micro
    fpr["micro"], tpr["micro"], _ = roc_curve(
        y_bin.ravel(), prob_mean.ravel()
    )
    roc_auc["micro"] = auc(fpr["micro"], tpr["micro"])

    # macro
    all_fpr = np.unique(np.concatenate([fpr[i] for i in range(n_classes)]))
    mean_tpr = np.zeros_like(all_fpr)

    for i in range(n_classes):
        mean_tpr += np.interp(all_fpr, fpr[i], tpr[i])

    mean_tpr /= n_classes
    roc_auc["macro"] = auc(all_fpr, mean_tpr)

    plt.figure()

    # 三个类别虚线
    for i in range(n_classes):
        plt.plot(
            fpr[i],
            tpr[i],
            linestyle="--",
            color=class_colors[i],
            label=f'Class {i} (AUC={roc_auc[i]:.3f})'
        )

    # micro、macro 实线
    plt.plot(
        fpr["micro"],
        tpr["micro"],
        linewidth=2,
        color=micro_color,
        label=f'micro (AUC={roc_auc["micro"]:.3f})'
    )

    plt.plot(
        all_fpr,
        mean_tpr,
        linewidth=2,
        color=macro_color,
        label=f'macro (AUC={roc_auc["macro"]:.3f})'
    )

    plt.plot([0, 1], [0, 1], 'k--')

    plt.xlabel("False Positive Rate")
    plt.ylabel("True Positive Rate")
    plt.title(title)
    plt.legend()

    filename = title.replace(" ", "_")
    plt.savefig(f"{filename}.pdf", dpi=600, bbox_inches="tight")

    # plt.show()


def plot_multiclass_pr(y_bin, prob_mean, title):

    n_classes = y_bin.shape[1]

    precision = dict()
    recall = dict()
    pr_auc = dict()

    for i in range(n_classes):
        precision[i], recall[i], _ = precision_recall_curve(
            y_bin[:, i], prob_mean[:, i]
        )
        pr_auc[i] = auc(recall[i], precision[i])

    # micro
    precision["micro"], recall["micro"], _ = precision_recall_curve(
        y_bin.ravel(), prob_mean.ravel()
    )
    pr_auc["micro"] = auc(recall["micro"], precision["micro"])

    # macro（对各类precision插值后平均）
    all_recall = np.unique(np.concatenate([recall[i] for i in range(n_classes)]))
    mean_precision = np.zeros_like(all_recall)

    for i in range(n_classes):
        mean_precision += np.interp(all_recall, recall[i][::-1], precision[i][::-1])

    mean_precision /= n_classes
    pr_auc["macro"] = auc(all_recall, mean_precision)

    plt.figure()

    # 三个类别虚线
    for i in range(n_classes):
        plt.plot(
            recall[i],
            precision[i],
            linestyle="--",
            color=class_colors[i],
            label=f'Class {i} (AUC={pr_auc[i]:.3f})'
        )

    # micro、macro 实线
    plt.plot(
        recall["micro"],
        precision["micro"],
        linewidth=2,
        color=micro_color,
        label=f'micro (AUC={pr_auc["micro"]:.3f})'
    )

    plt.plot(
        all_recall,
        mean_precision,
        linewidth=2,
        color=macro_color,
        label=f'macro (AUC={pr_auc["macro"]:.3f})'
    )

    plt.xlabel("Recall")
    plt.ylabel("Precision")
    plt.title(title)
    plt.legend()

    filename = title.replace(" ", "_")
    plt.savefig(f"{filename}.pdf", dpi=600, bbox_inches="tight")

    # plt.show()

def plot_confusion(y_true, prob_mean, title):

    y_pred = np.argmax(prob_mean, axis=1)

    labels = sorted(np.unique(y_true))  # [0,1,2]

    # 正常顺序计算混淆矩阵
    cm = confusion_matrix(y_true, y_pred, labels=labels)

    # 只反转行（True标签方向）
    cm = cm[::-1, :]

    # 显示标签：行反转，列正常
    display_labels_row = labels[::-1]
    display_labels_col = labels

    fig, ax = plt.subplots()

    from matplotlib.colors import LinearSegmentedColormap

    cmap = LinearSegmentedColormap.from_list(
        "custom_blue",
        ["#FFFFFF", "#4682B4"]
    )

    im = ax.imshow(cm, cmap=cmap)

    # 设置刻度
    ax.set_xticks(np.arange(len(display_labels_col)))
    ax.set_yticks(np.arange(len(display_labels_row)))

    ax.set_xticklabels(display_labels_col)
    ax.set_yticklabels(display_labels_row)

    ax.set_xlabel("Predicted Label")
    ax.set_ylabel("True Label")
    ax.set_title(title)

    # ===== 新增：白色网格线 =====
    ax.set_xticks(np.arange(-.5, len(display_labels_col), 1), minor=True)
    ax.set_yticks(np.arange(-.5, len(display_labels_row), 1), minor=True)

    ax.grid(which="minor", color="white", linestyle='-', linewidth=2)

    ax.tick_params(which="minor", bottom=False, left=False)
    # ==========================

    # 在格子里写数值
    for i in range(cm.shape[0]):
        for j in range(cm.shape[1]):
            ax.text(j, i, cm[i, j],
                    ha="center", va="center", color="black")

    plt.colorbar(im)

    filename = title.replace(" ", "_")
    plt.savefig(f"{filename}.pdf", dpi=600, bbox_inches="tight")

    # plt.show()


def plot_calibration(y_true, prob_mean, title):

    n_classes = prob_mean.shape[1]

    plt.figure()

    for i in range(n_classes):
        y_binary = (y_true == i).astype(int)

        prob_true, prob_pred = calibration_curve(
            y_binary,
            prob_mean[:, i],
            n_bins=10
        )

        plt.plot(
            prob_pred,
            prob_true,
            marker='o',
            color=class_colors[i],
            label=class_names[i]
        )

    plt.plot([0, 1], [0, 1], 'k--')
    plt.xlabel("Mean predicted probability")
    plt.ylabel("Fraction of positives")
    plt.title(title)
    plt.legend()

    filename = title.replace(" ", "_")
    plt.savefig(f"{filename}.pdf", dpi=600, bbox_inches="tight")

